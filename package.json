{
  "name": "workout-logger",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-navigation/bottom-tabs": "^7.18.2",
    "@react-navigation/native": "7.3.3",
    "@react-navigation/native-stack": "^7.17.5",
    "expo": "53.0.12",
    "expo-asset": "~11.1.7",
    "expo-file-system": "18.1.11",
    "expo-font": "~13.3.2",
    "expo-sqlite": "15.2.12",
    "react": "19.0.0",
    "react-native": "0.79.4",
    "react-native-safe-area-context": "5.4.1",
    "react-native-screens": "4.11.1"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@react-native/eslint-config": "^0.79.2",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.0.10",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.57.1",
    "eslint-plugin-jest": "^29.15.2",
    "jest": "^29.7.0",
    "jest-expo": "^53.0.7",
    "prettier": "^3.5.3",
    "react-test-renderer": "19.0.0",
    "ts-jest": "^29.4.0",
    "typescript": "~5.8.3"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^@app/(.*)$": "<rootDir>/src/app/$1",
      "^@pages/(.*)$": "<rootDir>/src/pages/$1",
      "^@widgets/(.*)$": "<rootDir>/src/widgets/$1",
      "^@features/(.*)$": "<rootDir>/src/features/$1",
      "^@entities/(.*)$": "<rootDir>/src/entities/$1",
      "^@shared/(.*)$": "<rootDir>/src/shared/$1"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|react-native-safe-area-context))"
    ]
  }
}

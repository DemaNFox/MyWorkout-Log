{
  "expo": {
    "name": "Workout Logger",
    "slug": "workout-logger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "platforms": [
      "android"
    ],
    "android": {
      "package": "com.workoutlogger.mvp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f4f7f6"
      }
    },
    "newArchEnabled": true,
    "plugins": [
      "expo-sqlite",
      "expo-asset",
      "expo-font"
    ]
  }
}
